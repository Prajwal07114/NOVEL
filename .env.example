# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017

# MongoDB Database Name
MONGODB_DB_NAME=novel_generator

# App Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
